# App
SECRET_KEY=change-me-to-a-long-random-value
SESSION_COOKIE_NAME=bucket_session
SESSION_MAX_AGE_SECONDS=604800
COOKIE_SECURE=true
APP_BASE_URL=https://your-service.up.railway.app
SUPERUSER_EMAIL=joaoccoliveira@live.com
DEFAULT_SUBDIRECTORY=general
# Comma-separated bootstrap signup tokens.
# Optional format per item: email@example.com:token-value
INITIAL_API_TOKENS=

# Storage (Cloudflare R2)
R2_PREFIX=cloudflare_domain
R2_BUCKET_NAME=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# Alternative to endpoint URL if you prefer deriving it in code:
# R2_ACCOUNT_ID=<account_id>

# Database
# Use Railway Postgres in production. Railway will set this automatically when attached.
DATABASE_URL=

# Optional local fallback DB path (not recommended for production)
SQLITE_PATH=bucket.db
